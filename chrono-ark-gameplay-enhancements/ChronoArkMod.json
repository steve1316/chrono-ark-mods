{
    "id": "GameplayEnhancements",
    "Title": "Gameplay Enhancements",
    "Author": "steve1316",
    "Description": "Performance, bug fix, and quality-of-life improvements for gameplay. Optionally eliminates Encyclopedia freezes via UI caching and deferred tab loading. Fixes the camp recruit button disappearing after save/load. Configurable starting Mana, Gold, and Soulstones for new runs.",
    "Version": "1.0.0",
    "Cover": "",
    "ModSettingEntries": [
        {
            "SettingType": "DropdownSetting",
            "SettingKey": "CollectionsOptimization",
            "DisplayName": "Cache Encyclopedia",
            "Description": "Caches the Encyclopedia UI and defers tab loading to eliminate freezes. Experimental — disable if the Encyclopedia behaves oddly.",
            "InitValue": 0,
            "Options": ["Off", "On"]
        },
        {
            "SettingType": "SliderSetting",
            "SettingKey": "StartingMana",
            "DisplayName": "Starting Mana",
            "Description": "Mana (AP) at the start of a new run.",
            "InitValue": 3,
            "Min": 1,
            "Max": 10,
            "StepSize": 1
        },
        {
            "SettingType": "SliderSetting",
            "SettingKey": "StartingGold",
            "DisplayName": "Starting Gold",
            "Description": "Gold at the start of a new run.",
            "InitValue": 0,
            "Min": 0,
            "Max": 1000,
            "StepSize": 50
        },
        {
            "SettingType": "SliderSetting",
            "SettingKey": "StartingSoulstones",
            "DisplayName": "Starting Soulstones",
            "Description": "Soulstones at the start of a new run.",
            "InitValue": 0,
            "Min": 0,
            "Max": 25,
            "StepSize": 1
        }
    ],
    "DefaultAssetBundlePath": "",
    "Dependencies": [],
    "NeedRestartWhenSettingChanged": false,
    "NeedReloadAllWhenEnabled": false,
    "NeedRestartWhenEnabled": true,
    "Uploader": "steve1316",
    "TagList": ["QoL"],
    "Visibility": "Public",
    "OnlyUploadFiles": true
}
